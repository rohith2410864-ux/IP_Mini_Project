# =====================================================
# FRONTEND ENVIRONMENT VARIABLES
# Copy this file to .env for local development
# Set these as Environment Variables on Render
# =====================================================

# Local development
VITE_FACULTY_SERVICE_URL=http://localhost:8081/api
VITE_STUDENT_SERVICE_URL=http://localhost:8082/api
VITE_EVENT_SERVICE_URL=http://localhost:8083/api

# Production (replace with your actual Render URLs)
# VITE_FACULTY_SERVICE_URL=https://your-faculty-service.onrender.com/api
# VITE_STUDENT_SERVICE_URL=https://your-student-service.onrender.com/api
# VITE_EVENT_SERVICE_URL=https://your-event-service.onrender.com/api
